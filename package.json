{
  "name": "nalesss-player",
  "version": "1.0.0",
  "description": "NalessS - Reproductor compartido estilo Nintendo",
  "main": "electron.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "app": "node_modules/.pnpm/electron@30.5.1/node_modules/electron/dist/electron.exe .",
    "build": "electron-builder"
  },
  "dependencies": {
    "axios": "^1.4.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.6.1"
  },
  "devDependencies": {
    "electron": "30.5.1",
    "electron-builder": "^24.0.0",
    "nodemon": "^3.0.1"
  },
  "build": {
    "appId": "com.nalesss.player",
    "productName": "NalessS",
    "win": {
      "icon": "public/assets/icon.ico",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "electron.js",
      "server.js",
      "public/**/*",
      "package.json",
      ".env"
    ],
    "extraResources": [
      {
        "from": "uploads",
        "to": "uploads"
      }
    ]
  }
}
